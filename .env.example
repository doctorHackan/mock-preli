# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository (owner/repo) — used by docker-compose to pull the image from GHCR
# Example: myusername/sust-preli-mock-2026
GITHUB_REPOSITORY=your-github-username/sust-preli-mock-2026

# Optional: override the model (default: openai/gpt-oss-120b)
# OPENROUTER_MODEL=openai/gpt-oss-120b

# Optional: application port (default: 8000)
# PORT=8000
